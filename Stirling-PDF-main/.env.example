# Copy this file to .env and fill in real values before running
# `docker compose up`. Never commit the real .env file — it holds secrets.
#
# These map onto settings.yml fields using Stirling's env-override convention
# (SECTION_SUBSECTION_FIELD), so you don't need to edit settings.yml directly
# or bake secrets into the image/volume.

# --- Initial admin account (only used on first startup, before any users exist) ---
SECURITY_INITIALLOGIN_USERNAME=admin
SECURITY_INITIALLOGIN_PASSWORD=changeme-before-first-boot

# --- Microsoft Entra ID (Azure AD) SSO ---
# From your Entra app registration (single-tenant, PHD Nigeria only):
SECURITY_OAUTH2_ISSUER=https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/v2.0
SECURITY_OAUTH2_CLIENTID=REPLACE_WITH_APPLICATION_CLIENT_ID
SECURITY_OAUTH2_CLIENTSECRET=REPLACE_WITH_CLIENT_SECRET_VALUE

# --- Org-facing config ---
SYSTEM_BACKENDURL=https://phd-smart-tools.example.internal
SYSTEM_FRONTENDURL=https://phd-smart-tools.example.internal

# --- Container runtime ---
PUID=1000
PGID=1000
UMASK=022
JAVA_CUSTOM_OPTS=
