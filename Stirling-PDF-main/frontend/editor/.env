###############################################################################
# Frontend environment variables for core and proprietary builds.
# Values can be overridden in the uncommitted sibling `.env.local` file.
# Note: This file is committed to Git, so should not contain any private keys.
###############################################################################

# API base URL — use / for same-origin (default for web builds)
VITE_API_BASE_URL=/

# Google Drive integration (PHD Nigeria — fill in if Drive integration is wanted)
VITE_GOOGLE_DRIVE_CLIENT_ID=
VITE_GOOGLE_DRIVE_API_KEY=
VITE_GOOGLE_DRIVE_APP_ID=

# Supabase configuration — NOT USED in core/self-hosted flavor.
# Left blank intentionally; core builds use the Spring backend's own login,
# not a cloud account system. Do not reintroduce Stirling's keys here.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Stripe checkout — NOT USED in core/self-hosted flavor. Internal tool, no billing.
VITE_STRIPE_PUBLISHABLE_KEY=

# PostHog analytics — disabled by default for internal deployment.
# Set your own self-hosted PostHog (or leave blank to disable telemetry entirely).
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=
